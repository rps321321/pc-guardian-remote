<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>PCGuardianRemote</AssemblyName>
    <RootNamespace>PCGuardianRemote</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ApplicationIcon>guardian.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="guardian.ico" LogicalName="guardian.ico" />
    <EmbeddedResource Include="cloudflared.exe" LogicalName="cloudflared.exe" />
  </ItemGroup>
</Project>
